# ===== Course Recommendation Bot - Environment Variables =====
# Copy this file to .env and fill in your values

# --- Flask ---
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET_KEY=change-me-to-another-random-string
FLASK_DEBUG=false
PORT=5000

# --- Database ---
DATABASE_URL=sqlite:///recommender.db

# --- AI Provider Keys (at least one recommended) ---
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...
